<div class="container mt-5 d-flex justify-content-center">
    <div class="card glassmorphism-card shadow-lg p-4">
        <h1 class="text-center text-primary mb-4">🔄 Modifier l'Équipe</h1>

        <form action="/equipe/<%= equipe.id %>/edit" method="post">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

            <div class="mb-4">
                <label class="form-label fw-bold">Nom de l'équipe</label>
                <input type="text" name="nomEquipe" class="form-control custom-input" value="<%= equipe.nomEquipe %>"
                    required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Chef d'équipe</label>
                <select name="chefEquipeId" class="form-select custom-input">
                    <option value="">-- Sélectionner --</option>
                    <% users.forEach(function(user) { %>
                        <option value="<%= user.id %>" <%=equipe.chefEquipeId===user.id ? 'selected' : '' %>>
                            <%= user.nom %>
                                <%= user.prenom %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <h3 class="mt-4 text-secondary fw-bold">📅 Dates d'affectation :</h3>
            <div class="card p-3 mb-3 glassmorphism-subcard">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date de Début</label>
                        <input type="date" name="dateDebut" id="equipe_dateDebut" class="form-control custom-input"
                            value="<%= equipe.dateDebut ? new Date(equipe.dateDebut).toISOString().substring(0, 10) : '' %>"
                            required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date de Fin</label>
                        <input type="date" name="dateFin" id="equipe_dateFin" class="form-control custom-input"
                            value="<%= equipe.dateFin ? new Date(equipe.dateFin).toISOString().substring(0, 10) : '' %>"
                            required>
                    </div>
                </div>
            </div>

            <h3 class="mt-4 text-secondary fw-bold">👥 Gestion des membres :</h3>
            <div class="row">
                <div class="col-md-6">
                    <h5 class="text-success">✅ Membres actuels</h5>
                    <div class="card p-3 mb-3 glassmorphism-subcard">
                        <% users.forEach(function(user) { %>
                            <% var isMember=currentMembers && currentMembers.includes(user.id); %>
                                <% if (isMember) { %>
                                    <div class="form-check custom-checkbox">
                                        <input type="checkbox" name="membres" value="<%= user.id %>"
                                            class="form-check-input" id="membre_<%= user.id %>" checked>
                                        <label class="form-check-label" for="membre_<%= user.id %>">
                                            <%= user.nom %>
                                                <%= user.prenom %>
                                        </label>
                                    </div>
                                    <% } %>
                                        <% }); %>
                    </div>
                </div>
                <div class="col-md-6">
                    <h5 class="text-warning">⚡ Utilisateurs disponibles</h5>
                    <div class="card p-3 mb-3 glassmorphism-subcard">
                        <% users.forEach(function(user) { %>
                            <% var isMember=currentMembers && currentMembers.includes(user.id); %>
                                <% if (!isMember) { %>
                                    <div class="form-check custom-checkbox">
                                        <input type="checkbox" name="membres" value="<%= user.id %>"
                                            class="form-check-input" id="membre_<%= user.id %>">
                                        <label class="form-check-label" for="membre_<%= user.id %>">
                                            <%= user.nom %>
                                                <%= user.prenom %>
                                        </label>
                                    </div>
                                    <% } %>
                                        <% }); %>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-glass btn-lg"><i class="fas fa-save"></i> Mettre à jour</button>
                <a href="/equipe" class="btn btn-outline-secondary ms-3"><i class="fas fa-arrow-left"></i> Retour</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.querySelector("form");
        form.addEventListener("submit", function (event) {
            let dateDebut = new Date(document.getElementById("equipe_dateDebut").value);
            let dateFin = new Date(document.getElementById("equipe_dateFin").value);
            if (dateFin <= dateDebut) { event.preventDefault(); alert("⚠️ La date de fin doit être postérieure à la date de début !"); }
        });
    });
</script>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
        max-width: 800px;
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .glassmorphism-subcard {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        padding: 20px;
    }

    .custom-input {
        border-radius: 10px;
        padding: 12px;
        font-size: 16px;
        background: rgba(255, 255, 255, 0.3);
    }

    .custom-checkbox .form-check-input {
        transform: scale(1.3);
        margin-right: 8px;
    }

    .btn-glass {
        background: linear-gradient(45deg, #00d4ff, #007bff);
        border: none;
        color: white;
        padding: 12px 20px;
        border-radius: 25px;
        font-weight: bold;
    }

    .btn-glass:hover {
        background: linear-gradient(45deg, #0096c7, #0056b3);
    }
</style>