<div class="container mt-5">
    <div class="card shadow-lg p-4 animated-card">
        <h1 class="text-center text-primary mb-4">👥 Gestion des Équipes</h1>

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" id="searchInput" class="form-control search-bar"
                        placeholder="Rechercher une équipe...">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                </div>
            </div>
            <div class="col-md-8 text-end">
                <a href="/equipe/new" class="btn btn-gradient btn-lg">
                    <i class="fas fa-plus"></i> Ajouter une Équipe
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table custom-table" id="teamTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom de l'Équipe</th>
                        <th>Membres</th>
                        <th>Date Début</th>
                        <th>Date Fin</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (equipes.length===0) { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted">Aucune équipe trouvée</td>
                        </tr>
                        <% } else { %>
                            <% equipes.forEach(function(equipe) { %>
                                <tr class="table-row">
                                    <td><strong>
                                            <%= equipe.id %>
                                        </strong></td>
                                    <td class="team-name">
                                        <%= equipe.nomEquipe %>
                                    </td>
                                    <td>
                                        <%= equipe.equipeUsers ? equipe.equipeUsers.length : 0 %>
                                    </td>
                                    <td>
                                        <%= equipe.dateDebut ? new Date(equipe.dateDebut).toLocaleDateString('fr-FR')
                                            : 'N/A' %>
                                    </td>
                                    <td>
                                        <%= equipe.dateFin ? new Date(equipe.dateFin).toLocaleDateString('fr-FR')
                                            : 'N/A' %>
                                    </td>
                                    <td class="actions">
                                        <a href="/equipe/<%= equipe.id %>" class="btn btn-circle btn-view"><i
                                                class="fas fa-eye"></i></a>
                                        <a href="/equipe/<%= equipe.id %>/edit" class="btn btn-circle btn-edit"><i
                                                class="fas fa-edit"></i></a>
                                        <form method="post" action="/equipe/<%= equipe.id %>/delete"
                                            onsubmit="return confirm('Voulez-vous vraiment supprimer cette équipe ?');"
                                            class="d-inline">
                                            <input type="hidden" name="_csrf"
                                                value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">
                                            <button class="btn btn-circle btn-delete"><i
                                                    class="fas fa-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-center mt-3">
            <button id="prevPage" class="btn btn-outline-primary me-2">⬅ Précédent</button>
            <span id="pageNumber" class="align-self-center"></span>
            <button id="nextPage" class="btn btn-outline-primary ms-2">Suivant ➡</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let currentPage = 1;
        const rowsPerPage = 10;
        let rows = document.querySelectorAll("#teamTable tbody tr.table-row");

        document.getElementById("searchInput").addEventListener("keyup", function () {
            let input = this.value.toLowerCase();
            rows.forEach(function (row) {
                let teamName = row.querySelector(".team-name").textContent.toLowerCase();
                row.style.display = teamName.includes(input) ? "" : "none";
            });
        });

        function showPage(page) {
            let start = (page - 1) * rowsPerPage;
            let end = start + rowsPerPage;
            rows.forEach(function (row, index) {
                row.style.display = index >= start && index < end ? "" : "none";
            });
            document.getElementById("pageNumber").textContent = "Page " + page;
        }

        document.getElementById("prevPage").addEventListener("click", function () {
            if (currentPage > 1) { currentPage--; showPage(currentPage); }
        });
        document.getElementById("nextPage").addEventListener("click", function () {
            if (currentPage < Math.ceil(rows.length / rowsPerPage)) { currentPage++; showPage(currentPage); }
        });

        if (rows.length > 0) showPage(currentPage);
    });
</script>

<style>
    .custom-table th {
        background: black;
        color: white;
        padding: 14px;
        text-align: center;
    }

    .custom-table {
        border-collapse: separate;
        border-spacing: 0 10px;
        width: 100%;
    }

    .custom-table td {
        background: #fafafa;
        padding: 14px;
        text-align: center;
        border-radius: 6px;
    }

    .btn-circle {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 18px;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .btn-view {
        border-color: #2196f3;
        color: #2196f3;
    }

    .btn-view:hover {
        background: #2196f3;
        color: white;
    }

    .btn-edit {
        border-color: #ff9800;
        color: #ff9800;
    }

    .btn-edit:hover {
        background: #ff9800;
        color: white;
    }

    .btn-delete {
        border-color: #f44336;
        color: #f44336;
    }

    .btn-delete:hover {
        background: #f44336;
        color: white;
    }

    .btn-gradient {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        border-radius: 25px;
        font-weight: bold;
    }

    .search-bar {
        border-radius: 30px;
        padding: 12px;
    }
</style>