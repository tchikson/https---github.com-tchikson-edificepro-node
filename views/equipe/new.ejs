<div class="container mt-5 d-flex justify-content-center">
    <div class="card glassmorphism-card shadow-lg p-4">
        <h1 class="text-center text-primary mb-4">🚀 Créer une Équipe</h1>

        <form action="/equipe" method="post">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

            <div class="mb-4">
                <label class="form-label fw-bold">Nom de l'équipe</label>
                <input type="text" name="nomEquipe" class="form-control custom-input" required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Chef d'équipe</label>
                <select name="chefEquipeId" class="form-select custom-input">
                    <option value="">-- Sélectionner --</option>
                    <% users.forEach(function(user) { %>
                        <option value="<%= user.id %>">
                            <%= user.nom %>
                                <%= user.prenom %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <h3 class="mt-4 text-secondary fw-bold">👥 Membres de l'équipe :</h3>
            <div class="card p-3 mb-3 glassmorphism-subcard">
                <div class="row">
                    <% users.forEach(function(user) { %>
                        <div class="col-md-4 mb-2">
                            <div class="form-check custom-checkbox">
                                <input type="checkbox" name="membres" value="<%= user.id %>" class="form-check-input"
                                    id="membre_<%= user.id %>">
                                <label class="form-check-label" for="membre_<%= user.id %>">
                                    <%= user.nom %>
                                        <%= user.prenom %>
                                </label>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>

            <h3 class="mt-4 text-secondary fw-bold">📅 Dates d'affectation :</h3>
            <div class="card p-3 mb-3 glassmorphism-subcard">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date de Début</label>
                        <input type="date" name="dateDebut" id="equipe_dateDebut" class="form-control custom-input"
                            required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date de Fin</label>
                        <input type="date" name="dateFin" id="equipe_dateFin" class="form-control custom-input"
                            required>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-glass btn-lg"><i class="fas fa-save"></i> Créer l'Équipe</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.querySelector("form");
        form.addEventListener("submit", function (event) {
            let dateDebut = new Date(document.getElementById("equipe_dateDebut").value);
            let dateFin = new Date(document.getElementById("equipe_dateFin").value);
            if (dateFin <= dateDebut) {
                event.preventDefault();
                alert("⚠️ La date de fin doit être postérieure à la date de début !");
            }
        });
    });
</script>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        max-width: 800px;
        width: 100%;
    }

    .glassmorphism-subcard {
        background: rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(8px);
        border-radius: 15px;
        padding: 20px;
    }

    .custom-input {
        border-radius: 10px;
        padding: 12px;
        font-size: 16px;
        background: rgba(255, 255, 255, 0.5);
    }

    .custom-checkbox .form-check-input {
        transform: scale(1.3);
        margin-right: 8px;
    }

    .btn-glass {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        padding: 12px 20px;
        border-radius: 25px;
        font-weight: bold;
    }

    .btn-glass:hover {
        background: linear-gradient(45deg, #0056b3, #0096c7);
    }
</style>