<div class="login-container">
    <div class="login-card">
        <div class="login-form">
            <h2 class="text-center">Se connecter</h2>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-danger">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/login" method="post">
                        <input type="hidden" name="_csrf"
                            value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

                        <div class="form-group mb-3">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" class="form-control"
                                value="<%= typeof lastEmail !== 'undefined' ? lastEmail : '' %>" required autofocus
                                autocomplete="email">
                        </div>

                        <div class="form-group mb-3">
                            <label for="password">Mot de passe</label>
                            <input type="password" id="password" name="password" class="form-control" required
                                autocomplete="current-password">
                        </div>

                        <button type="submit" class="btn btn-submit w-100">Se connecter</button>
                    </form>
        </div>

        <div class="login-image">
            <img src="https://www.francetravail.fr/files/live/sites/PE/files/secteurs-metiers/batiment-travaux-publics/btp-un-poids-lourds-850.jpg"
                alt="Illustration">
        </div>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
    }

    .login-card {
        display: flex;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        max-width: 800px;
        width: 100%;
    }

    .login-form {
        flex: 1;
        padding: 40px;
    }

    .login-image {
        flex: 1;
    }

    .login-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .btn-submit {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        padding: 12px;
        border-radius: 25px;
        font-weight: bold;
    }

    .btn-submit:hover {
        background: linear-gradient(45deg, #0056b3, #0096c7);
    }

    @media (max-width: 768px) {
        .login-card {
            flex-direction: column;
        }

        .login-image {
            display: none;
        }
    }
</style>