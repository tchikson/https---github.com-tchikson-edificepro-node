<div class="container mt-5 d-flex justify-content-center">
    <div class="glassmorphism-card shadow-lg p-5">
        <div class="glassmorphism-header text-center">
            <h2>👤 Créer un Utilisateur</h2>
        </div>

        <form action="/user" method="post">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

            <div class="mb-4">
                <label class="form-label fw-bold"><i class="fas fa-user"></i> Nom</label>
                <input type="text" name="nom" class="form-control custom-input" placeholder="Entrez le nom" required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold"><i class="fas fa-user"></i> Prénom</label>
                <input type="text" name="prenom" class="form-control custom-input" placeholder="Entrez le prénom"
                    required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold"><i class="fas fa-envelope"></i> Email</label>
                <input type="email" name="email" class="form-control custom-input" placeholder="Entrez l'email"
                    required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold"><i class="fas fa-lock"></i> Mot de passe</label>
                <div class="input-group">
                    <input type="password" name="password" id="passwordField" class="form-control custom-input"
                        placeholder="Entrez le mot de passe"
                        value="<%= typeof randomPassword !== 'undefined' ? randomPassword : '' %>"
                        oninput="validatePassword()" required>
                    <button class="btn btn-outline-secondary toggle-password" type="button" onclick="togglePassword()">
                        <i class="fas fa-eye" id="toggleIcon"></i>
                    </button>
                </div>
                <div class="password-strength mt-2">
                    <div class="progress" style="height: 8px;">
                        <div id="passwordStrength" class="progress-bar" role="progressbar" style="width: 0%;"></div>
                    </div>
                    <small id="passwordMessage" class="text-muted"></small>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold"><i class="fas fa-user-tag"></i> Rôle</label>
                <select name="roles" class="form-select custom-select">
                    <option value="ROLE_USER">👤 Utilisateur</option>
                    <option value="ROLE_ADMIN">👑 Administrateur</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold"><i class="fas fa-cogs"></i> Compétences</label>
                <div class="card p-3 glassmorphism-subcard">
                    <div class="row">
                        <% competences.forEach(function(comp) { %>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" name="competences" value="<%= comp.id %>"
                                        class="form-check-input" id="comp_<%= comp.id %>">
                                    <label class="form-check-label" for="comp_<%= comp.id %>">
                                        <%= comp.nomCompetence %>
                                    </label>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-glass btn-lg"><i class="fas fa-save"></i> Enregistrer</button>
                <a href="/user/list" class="btn btn-outline-secondary ms-3"><i class="fas fa-arrow-left"></i> Retour</a>
            </div>
        </form>
    </div>
</div>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(15px);
        border-radius: 25px;
        padding: 50px;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        max-width: 700px;
        width: 100%;
    }

    .glassmorphism-header {
        font-size: 28px;
        font-weight: bold;
        background: rgba(0, 123, 255, 0.2);
        padding: 15px;
        border-radius: 20px;
        margin-bottom: 25px;
    }

    .custom-input,
    .custom-select {
        border-radius: 12px;
        padding: 14px;
        font-size: 16px;
        background: rgba(255, 255, 255, 0.5);
        width: 100%;
    }

    .glassmorphism-subcard {
        background: rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(8px);
        border-radius: 15px;
        padding: 20px;
    }

    .form-check-input {
        transform: scale(1.3);
        margin-right: 10px;
    }

    .btn-glass {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        padding: 14px 24px;
        border-radius: 30px;
        font-weight: bold;
        box-shadow: 0 4px 15px rgba(0, 123, 255, 0.4);
    }

    .btn-glass:hover {
        background: linear-gradient(45deg, #0056b3, #0096c7);
    }

    .toggle-password {
        border-radius: 12px;
        border: none;
        background: rgba(255, 255, 255, 0.6);
    }
</style>

<script>
    function togglePassword() {
        var pf = document.getElementById("passwordField");
        var ti = document.getElementById("toggleIcon");
        if (pf.type === "password") { pf.type = "text"; ti.classList.remove("fa-eye"); ti.classList.add("fa-eye-slash"); }
        else { pf.type = "password"; ti.classList.remove("fa-eye-slash"); ti.classList.add("fa-eye"); }
    }

    function validatePassword() {
        var password = document.getElementById("passwordField").value;
        var bar = document.getElementById("passwordStrength");
        var msg = document.getElementById("passwordMessage");
        var strength = 0;
        if (password.length >= 12) strength += 25;
        if (/[A-Z]/.test(password)) strength += 25;
        if (/\d/.test(password)) strength += 25;
        if (/[\W_]/.test(password)) strength += 25;

        bar.style.width = strength + "%";
        bar.className = "progress-bar";
        if (strength < 50) { bar.classList.add("bg-danger"); msg.innerHTML = "Ajoutez une majuscule, un chiffre et un caractère spécial."; }
        else if (strength < 100) { bar.classList.add("bg-warning"); msg.innerHTML = "Mot de passe acceptable."; }
        else { bar.classList.add("bg-success"); msg.innerHTML = "Mot de passe sécurisé ! ✅"; }
    }
</script>