<div class="container mt-5 d-flex justify-content-center">
    <div class="glassmorphism-card shadow-lg p-4">
        <div class="glassmorphism-header text-center">
            <h2>👤 Mon Espace</h2>
        </div>

        <div class="glassmorphism-body">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="text-secondary"><i class="fas fa-info-circle"></i> Mes informations</h4>
                    <ul class="custom-list">
                        <li><strong>Nom:</strong>
                            <%= currentUser.nom %>
                        </li>
                        <li><strong>Prénom:</strong>
                            <%= currentUser.prenom %>
                        </li>
                        <li><strong>Email:</strong>
                            <%= currentUser.email %>
                        </li>
                        <li><strong>Rôle:</strong>
                            <% currentUser.roles.forEach(function(role) { %>
                                <span class="badge <%= role === 'ROLE_ADMIN' ? 'bg-danger' : 'bg-primary' %>">
                                    <%= role==='ROLE_ADMIN' ? 'Admin' : 'Utilisateur' %>
                                </span>
                                <% }); %>
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <h4 class="text-secondary"><i class="fas fa-cogs"></i> Mes Compétences</h4>
                    <% if (userProfile.competenceUsers && userProfile.competenceUsers.length> 0) { %>
                        <ul class="custom-list">
                            <% userProfile.competenceUsers.forEach(function(cu) { %>
                                <li><span class="badge competence-badge">
                                        <%= cu.competence ? cu.competence.nomCompetence : '' %>
                                    </span></li>
                                <% }); %>
                        </ul>
                        <% } else { %>
                            <p class="text-muted">Aucune compétence assignée.</p>
                            <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(12px);
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        max-width: 900px;
        width: 100%;
    }

    .glassmorphism-header {
        font-size: 28px;
        font-weight: bold;
        background: rgba(0, 123, 255, 0.2);
        padding: 20px;
        border-radius: 20px;
        margin-bottom: 25px;
    }

    .glassmorphism-body {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        padding: 20px;
    }

    .custom-list {
        list-style: none;
        padding: 0;
    }

    .custom-list li {
        padding: 10px;
        background: rgba(255, 255, 255, 0.2);
        margin-bottom: 8px;
        border-radius: 10px;
        font-weight: 500;
    }

    .competence-badge {
        background: #17a2b8;
        color: white;
        padding: 8px 12px;
        border-radius: 12px;
        display: inline-block;
    }
</style>