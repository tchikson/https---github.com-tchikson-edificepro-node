<form action="/user/edit-modal" method="post" id="editProfileForm">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

    <h5 class="mb-3">Modifier mon profil</h5>

    <div class="mb-3">
        <label class="form-label">Nom</label>
        <input type="text" name="nom" class="form-control" value="<%= currentUser.nom %>" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Prénom</label>
        <input type="text" name="prenom" class="form-control" value="<%= currentUser.prenom %>" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" value="<%= currentUser.email %>" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Nouveau mot de passe (optionnel)</label>
        <input type="password" name="password" class="form-control" placeholder="Laisser vide pour ne pas changer">
    </div>

    <button type="submit" class="btn btn-primary w-100">Enregistrer</button>
</form>