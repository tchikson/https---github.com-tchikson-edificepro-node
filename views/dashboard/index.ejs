<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-primary"><i class="fas fa-calendar-alt"></i> Planning des Chantiers</h1>
        <h5 class="text-muted">Bienvenue, <strong>
                <%= currentUser.nom %>
                    <%= currentUser.prenom %>
            </strong></h5>
    </div>

    <!-- Onglets -->
    <ul class="nav nav-tabs" id="dashboardTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#planning"><i class="fas fa-project-diagram"></i>
                Planning</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#list-chantier"><i class="fas fa-list"></i> Liste des
                Chantiers</a>
        </li>
    </ul>

    <div class="tab-content mt-3">
        <!-- Vue Gantt -->
        <div class="tab-pane fade show active" id="planning">
            <div class="card shadow-lg p-4">
                <h4 class="text-secondary"><i class="fas fa-calendar"></i> Diagramme Gantt</h4>

                <div class="row g-3 my-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Mois :</label>
                        <input type="month" id="monthPicker" class="form-control"
                            value="<%= new Date().toISOString().substring(0, 7) %>">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Statut :</label>
                        <select id="statusFilter" class="form-select">
                            <option value="all">Tous</option>
                            <option value="en_cours">En cours</option>
                            <option value="en_pause">En pause</option>
                            <option value="termine">Terminé</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Vue :</label>
                        <select id="viewMode" class="form-select">
                            <option value="Day">Jour</option>
                            <option value="Week">Semaine</option>
                            <option value="Month">Mois</option>
                        </select>
                    </div>
                </div>

                <div id="gantt-container" class="mt-3"></div>
            </div>
        </div>

        <!-- Liste des Chantiers -->
        <div class="tab-pane fade" id="list-chantier">
            <div class="card shadow-lg p-4">
                <h4 class="text-secondary"><i class="fas fa-list"></i> Liste des Chantiers</h4>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>Chantier</th>
                                <th>Statut</th>
                                <th>Date Début</th>
                                <th>Date Fin</th>
                                <th>Équipes Affectées</th>
                            </tr>
                        </thead>
                        <tbody id="chantierTableBody">
                            <% chantiers.forEach(function(chantier) { %>
                                <tr class="chantier-row" data-status="<%= chantier.status %>">
                                    <td>
                                        <%= chantier.lieu %>
                                    </td>
                                    <td>
                                        <% if (chantier.status==='en_cours' ) { %>
                                            <span class="badge bg-success">En cours</span>
                                            <% } else if (chantier.status==='en_pause' ) { %>
                                                <span class="badge bg-warning">En pause</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Terminé</span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= chantier.dateDebut ? new
                                            Date(chantier.dateDebut).toLocaleDateString('fr-FR') : 'N/A' %>
                                    </td>
                                    <td>
                                        <%= chantier.dateFin ? new Date(chantier.dateFin).toLocaleDateString('fr-FR')
                                            : 'N/A' %>
                                    </td>
                                    <td>
                                        <ul class="list-unstyled">
                                            <% if (chantier.affectations) { %>
                                                <% chantier.affectations.forEach(function(aff) { %>
                                                    <li><strong>
                                                            <%= aff.equipe ? aff.equipe.nomEquipe : '' %>
                                                        </strong></li>
                                                    <% }); %>
                                                        <% } %>
                                        </ul>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/frappe-gantt/0.5.0/frappe-gantt.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const chantierData = [
            <% chantiers.forEach(function (chantier) { %>
        {
            id: "<%= chantier.id %>",
            name: "<%= chantier.lieu %>",
            start: "<%= chantier.dateDebut ? new Date(chantier.dateDebut).toISOString().substring(0, 10) : '' %>",
            end: "<%= chantier.dateFin ? new Date(chantier.dateFin).toISOString().substring(0, 10) : '' %>",
            custom_class: "<%= chantier.status %>"
        },
            <% }); %>
        ];

        if (chantierData.length === 0) return;

        let gantt = new Gantt("#gantt-container", chantierData, {
            view_mode: "Day",
            language: "fr",
        });

        function filterData() {
            let selectedStatus = document.getElementById("statusFilter").value;
            let selectedMonth = document.getElementById("monthPicker").value;

            let filteredData = chantierData.filter(function (chantier) {
                let isStatusMatch = selectedStatus === "all" || chantier.custom_class === selectedStatus;
                let isMonthMatch = chantier.start.substring(0, 7) <= selectedMonth && chantier.end.substring(0, 7) >= selectedMonth;
                return isStatusMatch && isMonthMatch;
            });

            gantt.refresh(filteredData);
            filterTable(selectedStatus);
        }

        function filterTable(status) {
            document.querySelectorAll(".chantier-row").forEach(function (row) {
                row.style.display = (status === "all" || row.dataset.status === status) ? "" : "none";
            });
        }

        document.getElementById("statusFilter").addEventListener("change", filterData);
        document.getElementById("monthPicker").addEventListener("change", filterData);
        document.getElementById("viewMode").addEventListener("change", function () {
            gantt.change_view_mode(this.value);
        });
    });
</script>