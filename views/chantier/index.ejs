<div class="container mt-5">
    <div class="glassmorphism-card shadow-lg p-4">
        <h1 class="text-center text-primary mb-4">
            <span class="material-icons-round">construction</span> <span class="fw-bold">Gestion des Chantiers</span>
        </h1>

        <!-- Filtres -->
        <div class="row mb-4 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><span class="material-icons-round">search</span></span>
                    <input type="text" id="searchLieu" class="form-control search-bar"
                        placeholder="Rechercher un chantier par adresse...">
                </div>
            </div>
            <div class="col-md-4">
                <select id="filterStatus" class="form-select custom-select">
                    <option value="">📌 Filtrer par statut</option>
                    <option value="En cours">⚠️ En cours</option>
                    <option value="En pause">⏸️ En pause</option>
                    <option value="Terminé">✅ Terminé</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <a href="/chantier/new" class="btn btn-glass btn-lg">
                    <span class="material-icons-round">add_circle</span> Ajouter un Chantier
                </a>
            </div>
        </div>

        <!-- Tableau -->
        <div class="table-responsive">
            <table class="table custom-table" id="chantierTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th><span class="material-icons-round">location_on</span> Adresse</th>
                        <th><span class="material-icons-round">event</span> Date Début</th>
                        <th><span class="material-icons-round">event_available</span> Date Fin</th>
                        <th><span class="material-icons-round">assignment</span> Statut</th>
                        <th><span class="material-icons-round">settings</span> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (chantiers.length===0) { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted">Aucun chantier trouvé</td>
                        </tr>
                        <% } else { %>
                            <% chantiers.forEach(function(chantier) { %>
                                <tr class="chantier-row">
                                    <td><strong>
                                            <%= chantier.id %>
                                        </strong></td>
                                    <td class="chantier-lieu">
                                        <%= chantier.lieu %>
                                    </td>
                                    <td>
                                        <%= chantier.dateDebut ? new
                                            Date(chantier.dateDebut).toLocaleDateString('fr-FR') : 'N/A' %>
                                    </td>
                                    <td>
                                        <%= chantier.dateFin ? new Date(chantier.dateFin).toLocaleDateString('fr-FR')
                                            : 'N/A' %>
                                    </td>
                                    <td class="chantier-status">
                                        <% if (chantier.status==='en_cours' ) { %>
                                            <span class="badge status-badge ongoing"><span
                                                    class="material-icons-round">warning</span> En cours</span>
                                            <% } else if (chantier.status==='en_pause' ) { %>
                                                <span class="badge status-badge paused"><span
                                                        class="material-icons-round">pause_circle</span> En pause</span>
                                                <% } else if (chantier.status==='termine' ) { %>
                                                    <span class="badge status-badge completed"><span
                                                            class="material-icons-round">check_circle</span>
                                                        Terminé</span>
                                                    <% } else { %>
                                                        <span class="badge bg-light text-dark">Inconnu</span>
                                                        <% } %>
                                    </td>
                                    <td>
                                        <a href="/chantier/<%= chantier.id %>" class="btn btn-action btn-view"
                                            title="Voir">
                                            <span class="material-icons-round">visibility</span>
                                        </a>
                                        <a href="/chantier/<%= chantier.id %>/edit" class="btn btn-action btn-edit"
                                            title="Modifier">
                                            <span class="material-icons-round">edit</span>
                                        </a>
                                        <form method="post" action="/chantier/<%= chantier.id %>/delete"
                                            onsubmit="return confirm('Voulez-vous vraiment supprimer ce chantier ?');"
                                            class="d-inline">
                                            <input type="hidden" name="_csrf"
                                                value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">
                                            <button class="btn btn-action btn-delete" title="Supprimer">
                                                <span class="material-icons-round">delete</span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchLieu = document.getElementById("searchLieu");
        const filterStatus = document.getElementById("filterStatus");
        const rows = document.querySelectorAll(".chantier-row");

        function filterTable() {
            const search = searchLieu.value.toLowerCase();
            const status = filterStatus.value;
            rows.forEach(function (row) {
                const lieu = row.querySelector(".chantier-lieu").textContent.toLowerCase();
                const rowStatus = row.querySelector(".chantier-status").textContent.trim();
                const matchLieu = lieu.includes(search);
                const matchStatus = !status || rowStatus.includes(status);
                row.style.display = (matchLieu && matchStatus) ? "" : "none";
            });
        }

        searchLieu.addEventListener("input", filterTable);
        filterStatus.addEventListener("change", filterTable);
    });
</script>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 8px;
    }

    .custom-table th {
        background: #111;
        color: white;
        text-align: center;
        padding: 14px;
        font-weight: bold;
    }

    .custom-table td {
        background: white;
        padding: 12px;
        text-align: center;
        border-radius: 8px;
    }

    .status-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 8px 12px;
        border-radius: 12px;
        font-weight: bold;
    }

    .ongoing {
        background: #ffc107;
        color: black;
    }

    .paused {
        background: #6c757d;
        color: white;
    }

    .completed {
        background: #28a745;
        color: white;
    }

    .btn-action {
        border-radius: 50%;
        padding: 8px;
        margin: 2px;
        transition: all 0.3s ease;
    }

    .btn-view {
        background: #17a2b8;
        color: white;
    }

    .btn-edit {
        background: #ffc107;
        color: black;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
    }

    .btn-action:hover {
        transform: scale(1.1);
    }

    .search-bar {
        border-radius: 30px;
        padding: 12px;
    }

    .btn-glass {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        padding: 12px 20px;
        border-radius: 25px;
        font-weight: bold;
    }

    .btn-glass:hover {
        background: linear-gradient(45deg, #0056b3, #0096c7);
    }
</style>