<div class="container mt-5 d-flex justify-content-center">
    <div class="glassmorphism-card shadow-lg p-4">
        <div class="glassmorphism-header text-center">
            <h2><i class="fas fa-hard-hat"></i> Détails du Chantier</h2>
        </div>

        <div class="glassmorphism-body">
            <table class="table custom-table">
                <tbody>
                    <tr>
                        <th><i class="fas fa-map-marker-alt"></i> Adresse</th>
                        <td>
                            <%= chantier.lieu %>
                        </td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-calendar-day"></i> Date Début</th>
                        <td>
                            <%= chantier.dateDebut ? new Date(chantier.dateDebut).toLocaleDateString('fr-FR') : 'N/A' %>
                        </td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-calendar-check"></i> Date Fin</th>
                        <td>
                            <%= chantier.dateFin ? new Date(chantier.dateFin).toLocaleDateString('fr-FR') : 'N/A' %>
                        </td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-info-circle"></i> Statut</th>
                        <td>
                            <% if (chantier.status==='en_cours' ) { %>
                                <span class="badge status-badge ongoing">⚠️ En cours</span>
                                <% } else if (chantier.status==='en_pause' ) { %>
                                    <span class="badge status-badge paused">⏸️ En pause</span>
                                    <% } else if (chantier.status==='termine' ) { %>
                                        <span class="badge status-badge completed">✅ Terminé</span>
                                        <% } else { %>
                                            <span class="badge bg-light text-dark">Inconnu</span>
                                            <% } %>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="text-center mt-4 d-flex justify-content-center gap-3">
            <a href="/chantier" class="btn btn-outline-secondary btn-lg">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
            <a href="/chantier/<%= chantier.id %>/edit" class="btn btn-warning btn-lg">
                <i class="fas fa-edit"></i> Modifier
            </a>
            <form action="/chantier/<%= chantier.id %>/delete" method="POST"
                onsubmit="return confirm('Voulez-vous vraiment supprimer ce chantier ?');">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">
                <button class="btn btn-danger btn-lg"><i class="fas fa-trash"></i> Supprimer</button>
            </form>
        </div>
    </div>
</div>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 800px;
        width: 100%;
    }

    .glassmorphism-header {
        font-size: 22px;
        font-weight: bold;
        background: rgba(0, 123, 255, 0.2);
        padding: 15px;
        border-radius: 15px;
        margin-bottom: 20px;
    }

    .glassmorphism-body {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .custom-table th {
        text-align: left;
        background: transparent;
        font-weight: bold;
        padding: 10px;
    }

    .custom-table td {
        text-align: left;
        padding: 10px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
    }

    .status-badge {
        padding: 8px 12px;
        border-radius: 12px;
        font-weight: bold;
    }

    .ongoing {
        background: #ffc107;
        color: black;
    }

    .paused {
        background: #6c757d;
        color: white;
    }

    .completed {
        background: #28a745;
        color: white;
    }

    .d-flex.gap-3 {
        gap: 15px;
    }
</style>