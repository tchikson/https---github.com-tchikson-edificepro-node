<div class="container mt-5 d-flex justify-content-center">
    <div class="glassmorphism-card shadow-lg p-4">
        <h1 class="text-center text-primary mb-4"><i class="fas fa-hard-hat"></i> Créer un Chantier</h1>

        <form action="/chantier" method="post">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

            <div class="mb-4">
                <label class="form-label fw-bold">📍 Adresse du Chantier</label>
                <input type="text" name="lieu" class="form-control custom-input" placeholder="Ex: Paris, Lyon..."
                    required>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold">📅 Date de Début</label>
                    <input type="date" name="dateDebut" class="form-control custom-input" required>
                </div>
                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold">📅 Date de Fin</label>
                    <input type="date" name="dateFin" class="form-control custom-input" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">📌 Statut</label>
                <select name="status" class="form-select custom-input">
                    <option value="en_cours">En cours</option>
                    <option value="en_pause">En pause</option>
                    <option value="termine">Terminé</option>
                </select>
            </div>

            <h3 class="mt-4 text-secondary fw-bold"><i class="fas fa-tools"></i> Compétences requises :</h3>
            <div class="glassmorphism-subcard p-3 mb-4">
                <div class="row">
                    <% competences.forEach(function(comp) { %>
                        <div class="col-md-4 mb-2">
                            <div class="form-check custom-checkbox">
                                <input type="checkbox" name="competences" value="<%= comp.id %>"
                                    class="form-check-input" id="comp_<%= comp.id %>">
                                <label class="form-check-label" for="comp_<%= comp.id %>">
                                    <%= comp.nomCompetence %>
                                </label>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>

            <h3 class="mt-4 text-secondary fw-bold"><i class="fas fa-users"></i> Équipes Disponibles :</h3>
            <div class="glassmorphism-subcard p-3 mb-4">
                <div class="row">
                    <% equipes.forEach(function(equipe) { %>
                        <div class="col-md-4 mb-2">
                            <div class="form-check custom-checkbox">
                                <input type="checkbox" name="equipes" value="<%= equipe.id %>" class="form-check-input"
                                    id="equipe_<%= equipe.id %>">
                                <label class="form-check-label" for="equipe_<%= equipe.id %>">
                                    <%= equipe.nomEquipe %>
                                </label>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-glass btn-lg"><i class="fas fa-save"></i> Créer le
                    Chantier</button>
            </div>
        </form>
    </div>
</div>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 800px;
        width: 100%;
    }

    .glassmorphism-subcard {
        background: rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(8px);
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .custom-input {
        border-radius: 10px;
        padding: 12px;
        font-size: 16px;
        background: rgba(255, 255, 255, 0.5);
    }

    .custom-input:focus {
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid #007bff;
        box-shadow: 0 0 10px rgba(0, 123, 255, 0.3);
    }

    .custom-checkbox .form-check-input {
        transform: scale(1.3);
        margin-right: 8px;
    }

    .btn-glass {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        padding: 12px 20px;
        border-radius: 25px;
        font-weight: bold;
        box-shadow: 0 4px 15px rgba(0, 123, 255, 0.4);
    }

    .btn-glass:hover {
        background: linear-gradient(45deg, #0056b3, #0096c7);
    }
</style>