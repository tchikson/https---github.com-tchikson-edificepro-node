<div class="container mt-5 d-flex justify-content-center">
    <div class="glassmorphism-card shadow-lg p-4">
        <div class="glassmorphism-header text-center">
            <h2><i class="fas fa-cogs"></i> Détails de la Compétence</h2>
        </div>

        <div class="glassmorphism-body">
            <table class="table">
                <tr>
                    <th>ID</th>
                    <td>
                        <%= competence.id %>
                    </td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>
                        <%= competence.nomCompetence %>
                    </td>
                </tr>
            </table>
        </div>

        <div class="text-center mt-4 d-flex justify-content-center gap-3">
            <a href="/competence" class="btn btn-outline-secondary btn-lg"><i class="fas fa-arrow-left"></i> Retour</a>
            <a href="/competence/<%= competence.id %>/edit" class="btn btn-warning btn-lg"><i class="fas fa-edit"></i>
                Modifier</a>
            <form action="/competence/<%= competence.id %>/delete" method="POST"
                onsubmit="return confirm('Supprimer cette compétence ?');" class="d-inline">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">
                <button class="btn btn-danger btn-lg"><i class="fas fa-trash"></i> Supprimer</button>
            </form>
        </div>
    </div>
</div>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 600px;
        width: 100%;
    }

    .glassmorphism-header {
        font-size: 22px;
        font-weight: bold;
        background: rgba(0, 123, 255, 0.2);
        padding: 15px;
        border-radius: 15px;
        margin-bottom: 20px;
    }

    .glassmorphism-body {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        padding: 20px;
    }

    .d-flex.gap-3 {
        gap: 15px;
    }
</style>