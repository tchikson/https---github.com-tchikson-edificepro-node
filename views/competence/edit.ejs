<div class="container mt-5 d-flex justify-content-center">
    <div class="glassmorphism-card shadow-lg p-4">
        <h1 class="text-center text-primary mb-4"><i class="fas fa-cogs"></i> Modifier la Compétence</h1>

        <form action="/competence/<%= competence.id %>/edit" method="post">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken === 'function' ? csrfToken() : '' %>">

            <div class="mb-4">
                <label class="form-label fw-bold">Nom de la compétence</label>
                <input type="text" name="nomCompetence" class="form-control custom-input"
                    value="<%= competence.nomCompetence %>" required>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-glass btn-lg"><i class="fas fa-save"></i> Mettre à jour</button>
                <a href="/competence" class="btn btn-outline-secondary ms-3"><i class="fas fa-arrow-left"></i>
                    Retour</a>
            </div>
        </form>
    </div>
</div>

<style>
    .glassmorphism-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 600px;
        width: 100%;
    }

    .custom-input {
        border-radius: 10px;
        padding: 12px;
        font-size: 16px;
        background: rgba(255, 255, 255, 0.5);
    }

    .btn-glass {
        background: linear-gradient(45deg, #007bff, #00d4ff);
        border: none;
        color: white;
        padding: 12px 20px;
        border-radius: 25px;
        font-weight: bold;
    }
</style>